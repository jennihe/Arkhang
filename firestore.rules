rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // The one shared counter document. Anyone can read it, and anyone can
    // set the date — but only in the exact shape the app writes:
    //   { lastHang: "YYYY-MM-DD", updatedAt: <server timestamp> }
    match /arkie/hang {
      allow read: if true;

      allow create, update: if
        request.resource.data.keys().hasOnly(['lastHang', 'updatedAt'])
        && request.resource.data.keys().hasAll(['lastHang', 'updatedAt'])
        // lastHang must look like an ISO date, e.g. 2026-07-03
        && request.resource.data.lastHang is string
        && request.resource.data.lastHang.matches('^[0-9]{4}-[0-9]{2}-[0-9]{2}$')
        // updatedAt must be serverTimestamp() — clients can't backdate or spoof it
        && request.resource.data.updatedAt == request.time;

      allow delete: if false;
    }

    // Everything else in the database is locked down.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
